{
  "name": "codebuddy-history-viewer",
  "displayName": "CodeBuddy History Viewer",
  "description": "在左侧边栏显示 CodeBuddy 历史聊天内容",
  "version": "0.5.7",
  "publisher": "qiuzijian",
  "repository": {
    "type": "git",
    "url": "https://github.com/qiuzijian/codebuddy-history-viewer.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:codebuddy-history.view"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codebuddy-history",
          "title": "CodeBuddy 历史",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "codebuddy-history": [
        {
          "id": "codebuddy-history.view",
          "name": "聊天历史",
          "type": "webview",
          "contextualTitle": "CodeBuddy History"
        }
      ]
    },
    "commands": [
      {
        "command": "codebuddy-history.refresh",
        "title": "刷新历史记录",
        "icon": "$(refresh)"
      },
      {
        "command": "codebuddy-history.clear",
        "title": "清除历史记录",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codebuddy-history.refresh",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && npm run copy-sql-wasm",
    "copy-sql-wasm": "node -e \"const fs=require('fs');const p=require('path');const src=p.join('node_modules','sql.js','dist');const dst=p.join('out','sql-js');if(!fs.existsSync(dst))fs.mkdirSync(dst,{recursive:true});['sql-wasm.js','sql-wasm.wasm'].forEach(f=>{const s=p.join(src,f);const d=p.join(dst,f);if(!fs.existsSync(d)||fs.statSync(s).mtimeMs>fs.statSync(d).mtimeMs){fs.copyFileSync(s,d);console.log('Copied '+f)}})\"",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies --baseContentUrl https://example.com/ --baseImagesUrl https://example.com/ -o codebuddy-history-viewer.vsix",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.0",
    "@types/node": "^18.0.0",
    "@types/sql.js": "^1.4.11",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "fs-extra": "^11.2.0",
    "sql.js": "^1.14.1"
  }
}
